{
  "name": "logbook",
  "version": "0.1.0",
  "description": "CLI-first LLM harness for capturing, organizing, and processing notes.",
  "type": "module",
  "bin": {
    "logbook": "./dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "pnpm build && node dist/src/cli.js",
    "test": "pnpm build && node --test dist/test/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.8.0",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  }
}
