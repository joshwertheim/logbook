{
  "name": "logbook",
  "version": "0.1.0",
  "description": "CLI-first LLM harness for capturing, organizing, and processing notes.",
  "type": "module",
  "bin": {
    "logbook": "./dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src test",
    "start": "pnpm build && node dist/src/cli.js",
    "test": "pnpm build && node --test dist/test/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.8.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "eslint": "^10.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.62.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "zod": "^4.4.3"
  }
}
